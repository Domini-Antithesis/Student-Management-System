<!-- views/course_norm.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Assigned Courses</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Assigned Courses</h2>
        <% if (courses.length === 0) { %>
            <p>No courses assigned to you.</p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Course Code</th>
                        <th>Course Name</th>
                        <th>Description</th>
                        <th>Credits</th>
                    </tr>
                </thead>
                <tbody>
                    <% courses.forEach(course => { %>
                        <tr>
                            <td><%= course.courseCode %></td>
                            <td><%= course.courseName %></td>
                            <td><%= course.description %></td>
                            <td><%= course.credits %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
        <a href="/norm_main" id="backLink" class="back-link">←</a>
    </div>
</body>
</html>