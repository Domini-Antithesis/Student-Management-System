<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Course</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .container {
      max-width: 600px;
      margin: 50px auto;
      padding: 20px;
      background-color: #f9f9f9;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    h2 {
      text-align: center;
      margin-bottom: 20px;
    }

    label {
      display: block;
      margin-top: 10px;
      font-weight: bold;
    }

    input[type="text"],
    input[type="number"],
    textarea {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
      border: 1px solid #ccc;
      border-radius: 5px;
    }

    button {
      margin-top: 20px;
      padding: 10px 20px;
      background-color: #007bff;
      border: none;
      color: white;
      border-radius: 5px;
      cursor: pointer;
      width: 100%;
    }

    button:hover {
      background-color: #0056b3;
    }

    .back-link {
      position: absolute;
      top: 10px;
      left: 10px;
      font-size: 2rem;
      text-decoration: none;
      color: #007bff;
      transition: transform 0.3s ease, color 0.3s ease;
      background: none;
    }

    .back-link:hover {
      transform: scale(1.2);
      color: #0056b3;
    }

    body {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
      background: url('/images/overall_background_image.png') no-repeat center center fixed;
      background-size: cover;
    }
  </style>
</head>
<body>
  <div class="container">
    <a href="/courses/courses_main" class="back-link">←</a>
    <h2>Edit Course</h2>
    <form action="/courses/edit_course/<%= course._id %>" method="POST">
      <label for="courseCode">Course Code:</label>
      <input type="text" name="courseCode" id="courseCode" value="<%= course.courseCode %>" required>

      <label for="courseName">Course Name:</label>
      <input type="text" name="courseName" id="courseName" value="<%= course.courseName %>" required>

      <label for="description">Description:</label>
      <textarea name="description" id="description" rows="4"><%= course.description %></textarea>

      <label for="credits">Credits:</label>
      <input type="number" name="credits" id="credits" value="<%= course.credits %>" min="0" max="5" required>

      <button type="submit">Update Course</button>
    </form>
  </div>
</body>
</html>
