<!-- views/login_norm.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login as Student</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }
    .container {
      width: 40%; /* Reduced to half of the original 80% */
    }
    button {
      width: auto;
      padding: 5px 10px;
    }
  </style>
</head>
<body>
  <div class="container">
    <a href="/" class="home-link" id="homeLink" style="position: absolute; top: 10px; left: 10px; font-size: 2rem; text-decoration: none;">🏠</a>
    <h2>Login as Student</h2>
    <% if (error && error.length > 0) { %>
      <div class="error">
        <% error.forEach(msg => { %>
          <p><%= msg %></p>
        <% }) %>
      </div>
    <% } %>
    <form action="/login_norm" method="POST" id="studentLoginForm">
      <label for="studentID">Student ID:</label>
      <input type="text" name="studentID" id="studentID" required placeholder="Enter Student ID">
      <label for="password">Password:</label>
      <input type="password" name="password" id="password" required placeholder="Enter Password">
      <button type="submit" id="studentLoginButton">Login</button>
    </form>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>