<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Marks Search Result</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .back-link {
            position: absolute;
            top: 10px;
            left: 10px;
            font-size: 2rem;
            text-decoration: none;
            color: #007bff;
            transition: transform 0.3s ease, color 0.3s ease;
            background: none;
        }
        .back-link:hover {
            transform: scale(1.2);
            color: #0056b3;
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="/marks/update" class="back-link" id="backLink">←</a>
        <h2>Marks for Student ID: <%= studentID %></h2>
        <table class="marks-table">
            <thead>
                <tr>
                    <th>Course Code</th>
                    <th>MST</th>
                    <th>EST</th>
                    <th>Internal</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% marks.forEach(mark => { %>
                    <tr>
                        <td><%= mark.courseCode %></td>
                        <td><%= mark.mst %></td>
                        <td><%= mark.est %></td>
                        <td><%= mark.internal %></td>
                        <td><%= mark.total %></td>
                        <td><a href="/marks/update/edit/<%= mark.studentID %>" class="edit-btn" id="editButton">Update</a></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</body>
</html>