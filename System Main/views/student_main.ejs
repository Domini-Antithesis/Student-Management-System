<!-- views/student_main.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student_Main</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            display: flex;
            height: 100vh;
        }
        .sidebar {
            width: 200px;
            background-color: #007bff;
            padding: 20px;
            box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
            color: white;
            border-radius: 10px;
        }
        .sidebar h3 {
            text-align: center;
            margin-bottom: 20px;
            font-size: 1.5rem;
            color: #fff;
        }
        .sidebar ul {
            list-style: none;
            padding: 0;
        }
        .sidebar ul li {
            margin: 10px 0;
        }
        .sidebar ul li a {
            text-decoration: none;
            color: #fff;
            font-weight: bold;
            transition: color 0.3s ease;
        }
        .sidebar ul li a:hover {
            color: #d1ecf1;
        }
        .content {
            flex: 1;
            padding: 20px;
        }
        .course-box {
            border: 1px solid #ccc;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 5px;
            background-color: #fff;
        }
        form.search-bar {
            margin-bottom: 20px;
        }
        button {
            padding: 5px 10px;
            width: auto;
        }
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            padding: 5px 10px;
            color: #007bff;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            transition: background-color 0.3s ease, transform 0.2s ease;
        }
        .back-link:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Sidebar -->
        <div class="sidebar">
            <h3>Student Menu</h3>
            <ul>
                <li><a href="/student/add_student" id="addStudentLink">Add Student</a></li>
                <li><a href="/student/list_student" id="listStudentLink">List Students</a></li>
            </ul>
        </div>
        
        <!-- Main Content -->
        <div class="content">
            <!-- Back Link -->
            <a href="/admin_main" id="backLink" class="back-link">←</a>

            <!-- Search -->
            <form action="/student/search_student" method="get" class="search-bar">
                <input type="text" name="query" placeholder="Search students by Student ID..." required>
                <button type="submit">Search</button>
            </form>
        </div>
    </div>
    <script src="/js/main.js"></script>
</body>
</html>
